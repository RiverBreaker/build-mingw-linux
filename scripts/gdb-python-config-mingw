#!/bin/sh

# This shell script is used to fake Python. Gdb wants to be passed a
# Python interpreter, to run its own python-config.py program, which
# uses sysconfig. However, when cross-compiling, this doesn't work
# well since we would have to use the host Python, whose sysconfig
# module would return host values.
#
# This wrapper shell script ignores the python-config.py script passed
# as the first argument, and "emulates" its behavior.
set -e

# Default values - adjust these for your environment
# PYTHON_VERSION can be full version (e.g., 3.12.5) or short (e.g., 3.12)
PYTHON_VERSION="${PYTHON_VERSION:-3.12}"
# Extract major.minor version for paths and library names (3.12.5 -> 3.12)
PYTHON_ABIVER=$(echo "${PYTHON_VERSION}" | cut -d. -f1,2)

if [ $# -ne 2 ]; then
    echo "Bad # args." >&2
    exit 1
fi

if [ -z "${PYTHON_ABIVER}" ]; then
    echo "Environment variable PYTHON_ABIVER not set." >&2
    exit 1
fi

# The first argument is the path to python-config.py, ignore it.

case "$2" in
    --includes)
        echo "-I${OPT_DIR}/include/python${PYTHON_ABIVER}"
        ;;
    --ldflags)
        echo "-L${OPT_DIR}/lib -lpython${PYTHON_ABIVER}"
        ;;
    --exec-prefix)
        echo "/usr"
        ;;
    *)
        echo "Bad arg $2." >&2
        exit 1
        ;;
esac